<% content_for :title, "Admin dashboard — Subh Vivaah" %>

<div class="admin-main__head">
  <h1 class="admin-main__title">Dashboard</h1>
</div>

<div class="admin-stats">
  <% @counts.each do |label, n| %>
    <div class="admin-stat">
      <p class="admin-stat__value"><%= number_with_delimiter(n) %></p>
      <p class="admin-stat__label"><%= label.to_s.humanize %></p>
    </div>
  <% end %>
</div>

<p class="admin-prose" style="margin: 0; font-size: 0.875rem; color: #52525b;">
  Use the sidebar to manage members, verify profiles, review contact &amp; feedback, and edit blog content.
  Payments and subscriptions are read-mostly; subscription rows can be adjusted for support cases.
</p>
