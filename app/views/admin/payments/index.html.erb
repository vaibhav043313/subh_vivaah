<% content_for :title, "Payments — Admin" %>

<div class="admin-main__head">
  <h1 class="admin-main__title">Payments</h1>
</div>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>User</th>
        <th>Amount</th>
        <th>Status</th>
        <th>Plan</th>
        <th>Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @payments.each do |p| %>
        <tr>
          <td><%= p.id %></td>
          <td><%= link_to p.user.email, admin_user_path(p.user) %></td>
          <td><%= number_to_currency(p.amount_rupees, unit: "₹", precision: 2) %> <%= p.currency %></td>
          <td><span class="admin-badge"><%= p.status %></span></td>
          <td><%= p.plan_name.presence || "—" %></td>
          <td><%= p.created_at.strftime("%d %b %Y %H:%M") %></td>
          <td><%= link_to "View", admin_payment_path(p) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= admin_pagination(page: @page, total_pages: @total_pages) %>
