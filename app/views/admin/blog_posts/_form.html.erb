<%# locals: (blog_post:) %>
<% if blog_post.errors.any? %>
  <div class="admin-errors">
    <ul style="margin: 0; padding-left: 1.1rem;">
      <% blog_post.errors.full_messages.each do |m| %>
        <li><%= m %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: blog_post, url: (blog_post.persisted? ? admin_blog_post_path(blog_post) : admin_blog_posts_path), local: true, class: "admin-form" do |f| %>
  <div class="admin-form__field">
    <%= f.label :title %>
    <%= f.text_field :title, required: true %>
  </div>
  <div class="admin-form__field">
    <%= f.label :slug, "URL slug (lowercase, hyphens)" %>
    <%= f.text_field :slug, required: true, placeholder: "my-article-slug" %>
  </div>
  <div class="admin-form__field">
    <%= f.label :excerpt %>
    <%= f.text_area :excerpt, rows: 3 %>
  </div>
  <div class="admin-form__field">
    <%= f.label :body %>
    <%= f.text_area :body, required: true, rows: 16 %>
  </div>
  <div class="admin-form__field">
    <%= f.label :published_at, "Publish at (leave blank for draft)" %>
    <%= f.datetime_field :published_at, include_seconds: false %>
  </div>
  <div class="admin-btn-row">
    <%= f.submit(blog_post.persisted? ? "Update article" : "Create article", class: "btn btn--primary") %>
    <%= link_to "Cancel", admin_blog_posts_path, class: "btn btn--outline" %>
  </div>
<% end %>
