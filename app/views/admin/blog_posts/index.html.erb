<% content_for :title, "Blog — Admin" %>

<div class="admin-main__head">
  <h1 class="admin-main__title">Blog articles</h1>
  <%= link_to "New article", new_admin_blog_post_path, class: "btn btn--primary btn--sm" %>
</div>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Slug</th>
        <th>Published</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @blog_posts.each do |post| %>
        <tr>
          <td><%= post.title %></td>
          <td><code style="font-size: 0.8125rem;"><%= post.slug %></code></td>
          <td><%= post.published_at&.strftime("%d %b %Y") || "—" %></td>
          <td>
            <%= link_to "View", admin_blog_post_path(post) %>
            ·
            <%= link_to "Edit", edit_admin_blog_post_path(post) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
