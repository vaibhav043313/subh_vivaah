<% content_for :title, "Subscriptions — Admin" %>

<div class="admin-main__head">
  <h1 class="admin-main__title">Subscriptions</h1>
</div>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>User</th>
        <th>Plan</th>
        <th>Status</th>
        <th>Starts</th>
        <th>Ends</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @subscriptions.each do |s| %>
        <tr>
          <td><%= s.id %></td>
          <td><%= link_to s.user.email, admin_user_path(s.user) %></td>
          <td><%= s.plan_key %></td>
          <td><span class="admin-badge"><%= s.status %></span></td>
          <td><%= s.starts_on&.strftime("%d %b %Y") || "—" %></td>
          <td><%= s.ends_on&.strftime("%d %b %Y") || "—" %></td>
          <td>
            <%= link_to "View", admin_subscription_path(s) %>
            ·
            <%= link_to "Edit", edit_admin_subscription_path(s) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= admin_pagination(page: @page, total_pages: @total_pages) %>
