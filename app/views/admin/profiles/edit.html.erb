<% content_for :title, "Edit profile — Admin" %>

<div class="admin-main__head">
  <h1 class="admin-main__title">Edit profile</h1>
  <%= link_to "← Back", admin_profile_path(@profile), class: "btn btn--outline btn--sm" %>
</div>

<% if @profile.errors.any? %>
  <div class="admin-errors">
    <ul style="margin: 0; padding-left: 1.1rem;">
      <% @profile.errors.full_messages.each do |m| %>
        <li><%= m %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @profile, url: admin_profile_path(@profile), method: :patch, local: true, class: "admin-form" do |f| %>
  <div class="admin-form__field admin-form__check">
    <%= f.check_box :verified %>
    <%= f.label :verified, "Verified profile (shown as verified on the site)" %>
  </div>
  <div class="admin-form__field">
    <%= f.label :visibility, "Visibility" %>
    <%= f.select :visibility, Profile.visibilities.keys.map { |k| [ k.to_s.humanize, k ] }, { include_blank: "—" } %>
  </div>
  <div class="admin-form__field">
    <%= f.label :first_name %>
    <%= f.text_field :first_name %>
  </div>
  <div class="admin-form__field">
    <%= f.label :last_name %>
    <%= f.text_field :last_name %>
  </div>
  <div class="admin-form__field">
    <%= f.label :gender %>
    <%= f.select :gender, Profile.genders.keys.map { |k| [ k.to_s.humanize, k ] }, { include_blank: "—" } %>
  </div>
  <div class="admin-form__field">
    <%= f.label :city %>
    <%= f.text_field :city %>
  </div>
  <div class="admin-form__field">
    <%= f.label :state %>
    <%= f.text_field :state %>
  </div>
  <div class="admin-form__field">
    <%= f.label :country %>
    <%= f.text_field :country %>
  </div>
  <div class="admin-form__field">
    <%= f.label :religion %>
    <%= f.text_field :religion %>
  </div>
  <div class="admin-btn-row">
    <%= f.submit "Save changes", class: "btn btn--primary" %>
  </div>
<% end %>
