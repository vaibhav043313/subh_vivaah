<% content_for :title, "Feedback — Admin" %>

<div class="admin-main__head">
  <h1 class="admin-main__title">Feedback</h1>
  <%= link_to "← List", admin_feedback_submissions_path, class: "btn btn--outline btn--sm" %>
</div>

<dl class="admin-dl">
  <dt>Category</dt><dd><%= @feedback_submission.category %></dd>
  <dt>User</dt>
  <dd>
    <% if @feedback_submission.user %>
      <%= link_to @feedback_submission.user.email, admin_user_path(@feedback_submission.user) %>
    <% else %>
      <%= @feedback_submission.email.presence || "Anonymous" %>
    <% end %>
  </dd>
  <dt>Submitted</dt><dd><%= @feedback_submission.created_at.strftime("%d %b %Y %H:%M") %></dd>
</dl>

<h2 style="font-size: 1rem; margin: 1.5rem 0 0.5rem;">Message</h2>
<div class="admin-prose"><%= simple_format(@feedback_submission.body) %></div>
