<% content_for :title, "Feedback — Admin" %>

<div class="admin-main__head">
  <h1 class="admin-main__title">Feedback submissions</h1>
</div>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Category</th>
        <th>User / email</th>
        <th>Preview</th>
        <th>Submitted</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @submissions.each do |s| %>
        <tr>
          <td><span class="admin-badge"><%= s.category %></span></td>
          <td>
            <% if s.user %>
              <%= link_to s.user.email, admin_user_path(s.user) %>
            <% else %>
              <%= s.email.presence || "—" %>
            <% end %>
          </td>
          <td style="max-width: 280px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= truncate(s.body, length: 80) %></td>
          <td><%= s.created_at.strftime("%d %b %Y %H:%M") %></td>
          <td><%= link_to "Open", admin_feedback_submission_path(s) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= admin_pagination(page: @page, total_pages: @total_pages) %>
