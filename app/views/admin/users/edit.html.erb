<% content_for :title, "Edit user — Admin" %>

<div class="admin-main__head">
  <h1 class="admin-main__title">Edit user</h1>
  <%= link_to "← Back", admin_user_path(@user), class: "btn btn--outline btn--sm" %>
</div>

<% if @user.errors.any? %>
  <div class="admin-errors">
    <strong><%= pluralize(@user.errors.count, "error") %>:</strong>
    <ul style="margin: 0.5rem 0 0 1rem;">
      <% @user.errors.full_messages.each do |m| %>
        <li><%= m %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @user, url: admin_user_path(@user), method: :patch, local: true, class: "admin-form" do |f| %>
  <div class="admin-form__field">
    <%= f.label :phone_number, "Phone number" %>
    <%= f.telephone_field :phone_number %>
  </div>
  <div class="admin-form__field admin-form__check">
    <%= f.check_box :admin %>
    <%= f.label :admin, "Administrator (full admin panel access)" %>
  </div>
  <div class="admin-form__field admin-form__check">
    <%= f.check_box :premium %>
    <%= f.label :premium, "Premium member" %>
  </div>
  <div class="admin-btn-row">
    <%= f.submit "Save changes", class: "btn btn--primary" %>
  </div>
<% end %>
