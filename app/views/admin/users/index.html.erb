<% content_for :title, "Users — Admin" %>

<div class="admin-main__head">
  <h1 class="admin-main__title">Users</h1>
</div>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Email</th>
        <th>Admin</th>
        <th>Premium</th>
        <th>Joined</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.id %></td>
          <td><%= user.email %></td>
          <td><%= user.admin? ? tag.span("Yes", class: "admin-badge admin-badge--ok") : tag.span("—", class: "admin-badge admin-badge--no") %></td>
          <td><%= user.premium? ? "Yes" : "—" %></td>
          <td><%= user.created_at.strftime("%d %b %Y") %></td>
          <td><%= link_to "View", admin_user_path(user) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= admin_pagination(page: @page, total_pages: @total_pages) %>
