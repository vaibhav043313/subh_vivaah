<% content_for :title, "User ##{@user.id} — Admin" %>

<div class="admin-main__head">
  <h1 class="admin-main__title">User: <%= @user.email %></h1>
  <div class="admin-actions">
    <%= link_to "Edit", edit_admin_user_path(@user), class: "btn btn--primary btn--sm" %>
    <%= link_to "← Users", admin_users_path, class: "btn btn--outline btn--sm" %>
  </div>
</div>

<dl class="admin-dl">
  <dt>ID</dt><dd><%= @user.id %></dd>
  <dt>Email</dt><dd><%= @user.email %></dd>
  <dt>Phone</dt><dd><%= @user.phone_number.presence || "—" %></dd>
  <dt>Admin</dt><dd><%= @user.admin? ? "Yes" : "No" %></dd>
  <dt>Premium</dt><dd><%= @user.premium? ? "Yes" : "No" %></dd>
  <dt>Joined</dt><dd><%= @user.created_at.strftime("%d %b %Y %H:%M") %></dd>
  <dt>Last seen</dt><dd><%= @user.last_seen_at&.strftime("%d %b %Y %H:%M") || "—" %></dd>
  <% if @user.profile %>
    <dt>Profile</dt><dd><%= link_to "Open profile ##{@user.profile.id}", admin_profile_path(@user.profile) %></dd>
  <% end %>
</dl>
