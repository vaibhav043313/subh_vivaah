<% content_for :title, "My subscription — Subh Vivaah" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "site_pages", "data-turbo-track": "reload" %>
<% end %>

<div class="site-page">
  <%= render "shared/app_header" %>

  <main class="site-page__main">
    <div class="container">
      <%= render "shared/flash_strip" %>
      <h1 class="site-page__title">Subscription</h1>
      <p class="site-page__lead">Current plan and recent subscription history.</p>

      <% if @subscription %>
        <div class="card" style="padding: 1.5rem 1.65rem; margin-bottom: 2rem;">
          <h2 class="section__title" style="font-size: 1.125rem; margin-bottom: 0.75rem;">Active plan</h2>
          <dl style="margin: 0; display: grid; gap: 0.5rem; font-size: 0.9375rem;">
            <div><dt style="display: inline; font-weight: 600;">Plan:</dt> <dd style="display: inline; margin: 0;"><%= @subscription.plan_key %></dd></div>
            <div><dt style="display: inline; font-weight: 600;">Status:</dt> <dd style="display: inline; margin: 0;"><%= @subscription.status %></dd></div>
            <% if @subscription.starts_on %>
              <div><dt style="display: inline; font-weight: 600;">Starts:</dt> <dd style="display: inline; margin: 0;"><%= @subscription.starts_on.strftime("%-d %b %Y") %></dd></div>
            <% end %>
            <% if @subscription.ends_on %>
              <div><dt style="display: inline; font-weight: 600;">Ends:</dt> <dd style="display: inline; margin: 0;"><%= @subscription.ends_on.strftime("%-d %b %Y") %></dd></div>
            <% end %>
          </dl>
          <%= link_to "Upgrade or compare plans", pricing_path, class: "btn btn--primary btn--sm", style: "margin-top: 1rem;" %>
        </div>
      <% else %>
        <div class="card" style="padding: 1.5rem 1.65rem; margin-bottom: 2rem;">
          <p class="site-prose" style="margin: 0 0 1rem;">You do not have an active paid subscription on file.</p>
          <%= link_to "View membership plans", pricing_path, class: "btn btn--primary btn--sm" %>
        </div>
      <% end %>

      <% if @history.any? %>
        <h2 class="section__title" style="font-size: 1.125rem; margin-bottom: 0.75rem;">History</h2>
        <div class="card" style="padding: 0; overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Plan</th>
                <th>Status</th>
                <th>Period</th>
              </tr>
            </thead>
            <tbody>
              <% @history.each do |s| %>
                <tr>
                  <td><%= s.plan_key %></td>
                  <td><%= s.status %></td>
                  <td>
                    <% if s.starts_on && s.ends_on %>
                      <%= s.starts_on.strftime("%-d %b %Y") %> – <%= s.ends_on.strftime("%-d %b %Y") %>
                    <% else %>
                      <%= s.created_at.strftime("%-d %b %Y") %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>

      <p style="margin-top: 1.5rem;">
        <%= link_to "Payment history", payments_path, class: "btn btn--outline btn--sm" %>
      </p>
    </div>
  </main>

  <%= render "shared/site_footer" %>
</div>
