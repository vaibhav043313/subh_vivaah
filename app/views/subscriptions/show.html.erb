<% content_for :title, "My subscription — Subh Vivaah" %>

<div class="<%= site_page_shell_class %>">
  <%= render "shared/app_header" %>

  <main class="<%= site_page_main_class %>">
    <div class="container">
      <%= render "shared/flash_strip" %>
      <h1 class="<%= site_page_title_class %>">Subscription</h1>
      <p class="<%= site_page_lead_class %>">Current plan and recent subscription history.</p>

      <% if @subscription %>
        <div class="card mb-8 p-6 sm:px-[1.65rem] sm:py-6">
          <h2 class="section__title mb-3 text-lg">Active plan</h2>
          <dl class="m-0 grid gap-2 text-[15px]">
            <div><dt class="inline font-semibold">Plan:</dt> <dd class="inline m-0"><%= @subscription.plan_key %></dd></div>
            <div><dt class="inline font-semibold">Status:</dt> <dd class="inline m-0"><%= @subscription.status %></dd></div>
            <% if @subscription.starts_on %>
              <div><dt class="inline font-semibold">Starts:</dt> <dd class="inline m-0"><%= @subscription.starts_on.strftime("%-d %b %Y") %></dd></div>
            <% end %>
            <% if @subscription.ends_on %>
              <div><dt class="inline font-semibold">Ends:</dt> <dd class="inline m-0"><%= @subscription.ends_on.strftime("%-d %b %Y") %></dd></div>
            <% end %>
          </dl>
          <%= link_to "Upgrade or compare plans", pricing_path, class: "btn btn--primary btn--sm mt-4" %>
        </div>
      <% else %>
        <div class="card mb-8 p-6 sm:px-[1.65rem] sm:py-6">
          <p class="<%= site_prose_inline_class %> mb-4">You do not have an active paid subscription on file.</p>
          <%= link_to "View membership plans", pricing_path, class: "btn btn--primary btn--sm" %>
        </div>
      <% end %>

      <% if @history.any? %>
        <h2 class="section__title mb-3 text-lg">History</h2>
        <div class="card overflow-x-auto p-0">
          <table class="<%= site_data_table_class %>">
            <thead>
              <tr>
                <th>Plan</th>
                <th>Status</th>
                <th>Period</th>
              </tr>
            </thead>
            <tbody>
              <% @history.each do |s| %>
                <tr>
                  <td><%= s.plan_key %></td>
                  <td><%= s.status %></td>
                  <td>
                    <% if s.starts_on && s.ends_on %>
                      <%= s.starts_on.strftime("%-d %b %Y") %> – <%= s.ends_on.strftime("%-d %b %Y") %>
                    <% else %>
                      <%= s.created_at.strftime("%-d %b %Y") %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>

      <p class="mt-6">
        <%= link_to "Payment history", payments_path, class: "btn btn--outline btn--sm" %>
      </p>
    </div>
  </main>

  <%= render "shared/site_footer" %>
</div>
