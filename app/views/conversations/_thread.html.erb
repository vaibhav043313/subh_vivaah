<% peer = @peer_profile %>
<% peer_user = peer.user %>
<% age = profile_age_years(peer) %>
<% match_pct = profile_match_percent(peer, current_user) %>

<main class="messaging-main" aria-label="Messages with <%= profile_display_name(peer) %>" data-current-user-id="<%= current_user.id %>">
  <%= turbo_stream_from @conversation %>
  <%= link_to conversations_path(q: params[:q].presence), class: "messaging-back" do %>
    <span aria-hidden="true">←</span> All conversations
  <% end %>

  <header class="messaging-thread-head">
    <div class="messaging-thread-head__profile">
      <%= image_tag messaging_peer_thumb(peer), alt: "", class: "messaging-thread-head__avatar" %>
      <div>
        <h1 class="messaging-thread-head__name"><%= profile_display_name(peer) %><% if age %>, <%= age %><% end %></h1>
        <p class="messaging-thread-head__meta">
          <%= [ peer.city, peer.profession ].compact_blank.join(" • ").presence || "Member" %>
        </p>
        <p class="messaging-thread-head__score">Match score <%= match_pct %>%</p>
        <% if profile_online?(peer_user) %>
          <p class="messaging-thread-head__status">Available for chat</p>
        <% end %>
      </div>
    </div>
    <div class="messaging-thread-head__actions">
      <%= link_to "Profile", profile_path(peer), class: "messaging-thread-head__action" %>
      <span class="messaging-thread-head__action" title="Coming soon">Call</span>
      <span class="messaging-thread-head__action" title="Coming soon">Video</span>
      <span class="messaging-thread-head__action" title="Coming soon">Block</span>
      <span class="messaging-thread-head__action" title="Coming soon">Report</span>
    </div>
  </header>

  <div class="messaging-messages" id="conversation-messages">
    <% if @messages.any? %>
      <%= render @messages %>
    <% else %>
      <p class="messaging-system" id="conversation-messages-empty">No messages yet — send a thoughtful note to start the conversation.</p>
    <% end %>
  </div>

  <div class="messaging-composer">
    <div class="messaging-composer__quick" aria-hidden="true">
      <span class="messaging-composer__chip">Introduce</span>
      <span class="messaging-composer__chip">Ask details</span>
      <span class="messaging-composer__chip">Share interest</span>
    </div>
    <%= render "messages/form", conversation: @conversation %>
  </div>
</main>
