<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Account — Subh Vivaah" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "auth", "data-turbo-track": "reload" %>
    <%= yield :head %>
    <%= javascript_importmap_tags %>
  </head>
  <%# Full document navigations only: Turbo Drive + Devise session POST→redirect often fails until refresh. %>
  <body class="auth-body" data-turbo="false">
    <%= render "users/shared/auth_header" %>

    <% flash.each do |type, message| %>
      <% next if message.blank? %>
      <div class="auth-flash auth-flash--<%= type == "notice" ? "notice" : "alert" %>" role="alert">
        <%= message %>
      </div>
    <% end %>

    <main class="auth-main">
      <%= yield %>
    </main>
  </body>
</html>
