<header class="app-header<%= ' app-header--guest' unless user_signed_in? %>" data-controller="mobile-menu">
  <div class="app-header__backdrop" data-action="click->mobile-menu#closeOnBackdrop" aria-hidden="true"></div>

  <div class="app-header__inner container container--wide">
    <div class="app-header__logo-wrap">
      <%= link_to root_path, class: "site-logo" do %>
        <span class="site-logo__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        </span>
        <span class="site-logo__text">Subh Vivaah</span>
      <% end %>
    </div>

    <button type="button" class="app-header__menu-btn" aria-expanded="false" aria-controls="app-header-menu" data-mobile-menu-target="toggle" data-action="mobile-menu#toggle">
      <span class="visually-hidden">Menu</span>
      <span class="app-header__menu-bars" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <div id="app-header-menu" class="app-header__sheet" data-mobile-menu-target="panel" data-action="click->mobile-menu#closeOnLink">
      <nav class="app-header__nav" aria-label="Primary">
        <%= link_to "Home", root_path, class: "app-header__nav-link #{'is-active' if controller_name == 'home'}" %>
        <%= link_to "Search & Browse", profiles_path, class: "app-header__nav-link #{'is-active' if controller_name == 'profiles' && action_name == 'index'}" %>
        <% if user_signed_in? %>
          <%= link_to "Messages", conversations_path, class: "app-header__nav-link #{'is-active' if controller_name == 'conversations'}" %>
        <% end %>
        <%= link_to "Membership", pricing_path, class: "app-header__nav-link #{'is-active' if controller_name == 'pricing'}" %>
        <% unless user_signed_in? %>
          <%= link_to "How it works", root_path(anchor: "how-verified"), class: "app-header__nav-link" %>
        <% end %>
      </nav>

      <% if user_signed_in? %>
        <%= form_with url: profiles_path, method: :get, local: true, class: "app-header__search", data: { action: "submit->mobile-menu#close" } do %>
          <span class="app-header__search-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </span>
          <label class="visually-hidden" for="header-search-q">Search by name</label>
          <input type="search" id="header-search-q" name="q" value="<%= params[:q] %>" placeholder="Search by name, ID…" class="app-header__search-input" autocomplete="off">
        <% end %>
      <% end %>
    </div>

    <div class="app-header__actions">
      <% if user_signed_in? %>
        <%= link_to "My Matches", "#", class: "btn btn--primary btn--sm app-header__matches" %>
        <button type="button" class="app-header__icon-btn" aria-label="Notifications">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </button>

        <details class="app-header__user-menu">
          <summary class="app-header__user-summary">
            <span class="app-header__avatar" aria-hidden="true">
              <% uid = current_user.id %>
              <%= image_tag "https://i.pravatar.cc/80?u=#{uid}", alt: "", class: "app-header__avatar-img" %>
            </span>
            <span class="app-header__user-text">
              <span class="app-header__user-name"><%= current_user.profile&.first_name.presence || current_user.email.split("@").first.titleize %></span>
              <span class="app-header__user-tier"><%= current_user.premium? ? "Premium Member" : "Member" %></span>
            </span>
          </summary>
          <div class="app-header__dropdown">
            <%= link_to "Account settings", edit_user_registration_path, class: "app-header__dropdown-link" %>
            <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "app-header__dropdown-link" %>
          </div>
        </details>
      <% else %>
        <%= link_to "Sign In", new_user_session_path, class: "btn btn--outline btn--sm" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "btn btn--primary btn--sm" %>
      <% end %>
    </div>
  </div>
</header>
