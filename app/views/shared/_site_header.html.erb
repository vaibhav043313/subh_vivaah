<header class="site-header" data-controller="mobile-menu">
  <div class="site-header__backdrop" data-action="click->mobile-menu#closeOnBackdrop" aria-hidden="true"></div>

  <div class="site-header__inner container">
    <%= link_to root_path, class: "site-logo" do %>
      <span class="site-logo__icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      </span>
      <span class="site-logo__text">Subh Vivaah</span>
    <% end %>

    <button type="button" class="site-header__menu-btn" aria-expanded="false" aria-controls="site-primary-nav" data-mobile-menu-target="toggle" data-action="mobile-menu#toggle">
      <span class="visually-hidden">Menu</span>
      <span class="site-header__menu-bars" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <nav id="site-primary-nav" class="site-nav" aria-label="Primary" data-mobile-menu-target="panel" data-action="click->mobile-menu#closeOnLink">
      <%= link_to "Search", user_signed_in? ? profiles_path : "#quick-search", class: "site-nav__link" %>
      <%= link_to "Browse", user_signed_in? ? profiles_path : "#featured-profiles", class: "site-nav__link" %>
      <%= link_to "How it Works", "#how-verified", class: "site-nav__link" %>
      <%= link_to "Pricing", "#pricing", class: "site-nav__link" %>
    </nav>

    <div class="site-header__actions">
      <% if user_signed_in? %>
        <%= link_to "Account", edit_user_registration_path, class: "btn btn--outline btn--sm" %>
        <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "btn btn--primary btn--sm" %>
      <% else %>
        <%= link_to "Sign In", new_user_session_path, class: "btn btn--outline btn--sm" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "btn btn--primary btn--sm" %>
      <% end %>
    </div>
  </div>
</header>
