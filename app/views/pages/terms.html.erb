<% content_for :title, "Terms & conditions — Subh Vivaah" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "site_pages", "data-turbo-track": "reload" %>
<% end %>

<div class="site-page">
  <%= render "shared/app_header" %>

  <main class="site-page__main">
    <div class="container">
      <%= render "shared/flash_strip" %>
      <h1 class="site-page__title">Terms &amp; conditions</h1>
      <p class="site-page__lead">
        Please read these terms before using Subh Vivaah. This is a concise placeholder; replace with counsel-approved legal text before production.
      </p>
      <div class="site-prose card" style="padding: 1.5rem 1.65rem;">
        <h2>1. Using the service</h2>
        <p>By accessing Subh Vivaah you agree to use the platform lawfully, respect other members, and provide accurate information to the best of your ability.</p>

        <h2>2. Accounts &amp; eligibility</h2>
        <p>You are responsible for your account credentials and for activity under your account. You must meet any age and eligibility requirements stated at registration.</p>

        <h2>3. Content &amp; conduct</h2>
        <p>Harassment, spam, misuse of contact information, impersonation, or illegal content is prohibited. We may suspend or remove accounts that violate these rules or <%= link_to "community expectations described in our FAQ", faq_path %>.</p>

        <h2>4. Subscriptions &amp; payments</h2>
        <p>Paid features, renewal, refunds, and taxes will be governed by the checkout terms you accept at purchase. Until payment is integrated, treat <%= link_to "pricing", pricing_path %> as indicative.</p>

        <h2>5. Limitation of liability</h2>
        <p>The service is provided “as is.” To the extent permitted by law, Subh Vivaah is not liable for indirect or consequential damages arising from use of the platform.</p>

        <h2>6. Changes</h2>
        <p>We may update these terms. Continued use after changes constitutes acceptance of the revised terms.</p>

        <p>For questions, <%= link_to "contact us", contact_path %>.</p>
      </div>
    </div>
  </main>

  <%= render "shared/site_footer" %>
</div>
