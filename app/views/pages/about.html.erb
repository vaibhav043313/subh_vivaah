<% content_for :title, "About us — Subh Vivaah" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "site_pages", "data-turbo-track": "reload" %>
<% end %>

<div class="site-page">
  <%= render "shared/app_header" %>

  <main class="site-page__main">
    <div class="container">
      <%= render "shared/flash_strip" %>
      <h1 class="site-page__title">About Subh Vivaah</h1>
      <p class="site-page__lead">
        We help families and individuals find serious, respectful matches with privacy and care at the centre.
      </p>
      <div class="site-prose card" style="padding: 1.5rem 1.65rem;">
        <h2>Our approach</h2>
        <p>
          Subh Vivaah is built for people who want a thoughtful matrimony experience: clear profiles, sensible search,
          and tools to connect when both sides are comfortable. We combine verification signals, community guidelines,
          and support so members can explore with confidence.
        </p>
        <h2>What you can do here</h2>
        <ul>
          <li>Create a detailed profile and highlight what matters to you</li>
          <li>Browse and search with filters that respect your preferences</li>
          <li>Message safely when you are ready to talk</li>
          <li>Upgrade for contact details and premium visibility when it fits your journey</li>
        </ul>
        <p>
          Have questions? <%= link_to "Contact us", contact_path %> or read the <%= link_to "FAQ", faq_path %>.
        </p>
      </div>
    </div>
  </main>

  <%= render "shared/site_footer" %>
</div>
