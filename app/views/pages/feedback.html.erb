<% content_for :title, "Feedback — Subh Vivaah" %>

<div class="<%= site_page_shell_class %>">
  <%= render "shared/app_header" %>

  <main class="<%= site_page_main_class %>">
    <div class="container">
      <%= render "shared/flash_strip" %>
      <h1 class="<%= site_page_title_class %>">Feedback &amp; report an issue</h1>
      <p class="<%= site_page_lead_class %>">
        Tell us what is working, what is not, or report inappropriate behaviour. We review every submission.
      </p>

      <% if @feedback.errors.any? %>
        <div class="<%= site_form_errors_class %>">
          <strong>Please fix the following:</strong>
          <ul class="mt-2 list-disc pl-5">
            <% @feedback.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @feedback, url: submit_feedback_path, method: :post, local: true, class: site_form_card_class do |f| %>
        <% unless user_signed_in? %>
          <div class="<%= site_form_field_class %>">
            <%= f.label :email, "Email (so we can reply)" %>
            <%= f.email_field :email, required: true, autocomplete: "email" %>
          </div>
        <% end %>
        <div class="<%= site_form_field_class %>">
          <%= f.label :category, "Category" %>
          <%= f.select :category, [["General feedback", "general"], ["Bug / technical issue", "bug"], ["Safety / report member", "safety"], ["Billing / subscription", "billing"]] %>
        </div>
        <div class="<%= site_form_field_class %>">
          <%= f.label :body, "Details" %>
          <%= f.text_area :body, required: true, placeholder: "What happened? What did you expect?" %>
        </div>
        <%= f.submit "Submit feedback", class: "btn btn--primary self-start" %>
      <% end %>
    </div>
  </main>

  <%= render "shared/site_footer" %>
</div>
