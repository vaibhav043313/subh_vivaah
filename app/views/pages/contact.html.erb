<% content_for :title, "Contact us — Subh Vivaah" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "site_pages", "data-turbo-track": "reload" %>
<% end %>

<div class="site-page">
  <%= render "shared/app_header" %>

  <main class="site-page__main">
    <div class="container">
      <%= render "shared/flash_strip" %>
      <h1 class="site-page__title">Contact us</h1>
      <p class="site-page__lead">
        Share your question or feedback. We read every message and reply as soon as we can.
      </p>

      <% if @contact_message.errors.any? %>
        <div class="site-form__errors" style="max-width: 28rem; margin-bottom: 1rem;">
          <strong>Please fix the following:</strong>
          <ul style="margin: 0.5rem 0 0; padding-left: 1.25rem;">
            <% @contact_message.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @contact_message, url: submit_contact_path, method: :post, local: true, class: "site-form card", style: "padding: 1.5rem 1.65rem;" do |f| %>
        <div class="site-form__field">
          <%= f.label :name, "Your name" %>
          <%= f.text_field :name, required: true, autocomplete: "name" %>
        </div>
        <div class="site-form__field">
          <%= f.label :email, "Email" %>
          <%= f.email_field :email, required: true, autocomplete: "email" %>
        </div>
        <div class="site-form__field">
          <%= f.label :subject, "Subject (optional)" %>
          <%= f.text_field :subject, autocomplete: "off" %>
        </div>
        <div class="site-form__field">
          <%= f.label :body, "Message" %>
          <%= f.text_area :body, required: true %>
        </div>
        <%= f.submit "Send message", class: "btn btn--primary", style: "align-self: flex-start;" %>
      <% end %>
    </div>
  </main>

  <%= render "shared/site_footer" %>
</div>
