<% content_for :title, "Blog & articles — Subh Vivaah" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "site_pages", "data-turbo-track": "reload" %>
<% end %>

<div class="site-page">
  <%= render "shared/app_header" %>

  <main class="site-page__main">
    <div class="container">
      <%= render "shared/flash_strip" %>
      <h1 class="site-page__title">Blog &amp; articles</h1>
      <p class="site-page__lead">
        Tips, stories, and guides for your matrimony journey.
      </p>

      <% if @posts.any? %>
        <ul class="blog-list">
          <% @posts.each do |post| %>
            <li>
              <article class="blog-card card">
                <p class="blog-card__meta">
                  <%= post.published_at&.strftime("%-d %b %Y") %>
                </p>
                <h2 class="blog-card__title">
                  <%= link_to post.title, blog_post_path(post.slug) %>
                </h2>
                <% if post.excerpt.present? %>
                  <p class="blog-card__excerpt"><%= post.excerpt %></p>
                <% end %>
                <%= link_to "Read more →", blog_post_path(post.slug), class: "btn btn--outline btn--sm", style: "margin-top: 0.75rem;" %>
              </article>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="site-page__lead" style="margin-bottom: 0;">No articles yet. Check back soon.</p>
      <% end %>
    </div>
  </main>

  <%= render "shared/site_footer" %>
</div>
