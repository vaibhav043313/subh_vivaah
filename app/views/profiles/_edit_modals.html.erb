<dialog id="profile-edit-personal" class="profile-modal" data-controller="modal" data-action="click->modal#backdropClose">
  <div class="profile-modal__inner">
    <div class="profile-modal__head">
      <h3 class="profile-modal__title">Personal details</h3>
      <button type="button" class="profile-modal__close" aria-label="Close" data-action="click->modal#close">&times;</button>
    </div>
    <%= form_with model: profile, url: profile_path(profile), method: :patch, html: { class: "profile-modal__form", data: { turbo: false } } do |f| %>
      <%= hidden_field_tag :section, "personal" %>
      <div class="profile-modal__field">
        <%= f.label :date_of_birth, class: "profile-modal__label" %>
        <%= f.date_field :date_of_birth, class: "profile-modal__input", max: 18.years.ago.to_date, min: 80.years.ago.to_date %>
      </div>
      <div class="profile-modal__field">
        <%= f.label :gender, class: "profile-modal__label" %>
        <%= f.select :gender, Profile.genders.keys.map { |k| [ k.to_s.humanize, k ] }, {}, { class: "profile-modal__input" } %>
      </div>
      <div class="profile-modal__field">
        <%= f.label :height_cm, "Height (cm)", class: "profile-modal__label" %>
        <%= f.number_field :height_cm, class: "profile-modal__input", min: 100, max: 250, step: 1 %>
      </div>
      <div class="profile-modal__field">
        <%= f.label :marital_status, class: "profile-modal__label" %>
        <%= f.text_field :marital_status, class: "profile-modal__input" %>
      </div>
      <div class="profile-modal__field">
        <%= f.label :religion, class: "profile-modal__label" %>
        <%= f.text_field :religion, class: "profile-modal__input" %>
      </div>
      <div class="profile-modal__field">
        <%= f.label :caste, "Caste / community", class: "profile-modal__label" %>
        <%= f.text_field :caste, class: "profile-modal__input" %>
      </div>
      <div class="profile-modal__field">
        <%= f.label :mother_tongue, class: "profile-modal__label" %>
        <%= f.text_field :mother_tongue, class: "profile-modal__input" %>
      </div>
      <div class="profile-modal__actions">
        <%= f.submit "Save", class: "btn btn--primary" %>
        <button type="button" class="btn btn--outline" data-action="click->modal#close">Cancel</button>
      </div>
    <% end %>
  </div>
</dialog>

