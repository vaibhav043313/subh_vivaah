<%# locals: (profile:) %>
<% return unless profile_editable?(profile) %>

<dialog id="profile-edit-basics" class="profile-modal" data-controller="modal" data-action="click->modal#backdropClose">
  <div class="profile-modal__inner">
    <div class="profile-modal__head">
      <h3 class="profile-modal__title">Name</h3>
      <button type="button" class="profile-modal__close" aria-label="Close" data-action="click->modal#close">&times;</button>
    </div>
    <%= form_with model: profile, url: profile_path(profile), method: :patch, html: { class: "profile-modal__form", data: { turbo: false } } do |f| %>
      <%= hidden_field_tag :section, "basics" %>
      <div class="profile-modal__field">
        <%= f.label :first_name, class: "profile-modal__label" %>
        <%= f.text_field :first_name, class: "profile-modal__input", autocomplete: "given-name" %>
      </div>
      <div class="profile-modal__field">
        <%= f.label :last_name, class: "profile-modal__label" %>
        <%= f.text_field :last_name, class: "profile-modal__input", autocomplete: "family-name" %>
      </div>
      <div class="profile-modal__actions">
        <%= f.submit "Save", class: "btn btn--primary" %>
        <button type="button" class="btn btn--outline" data-action="click->modal#close">Cancel</button>
      </div>
    <% end %>
  </div>
</dialog>

<dialog id="profile-edit-photos" class="profile-modal" data-controller="modal" data-action="click->modal#backdropClose">
  <div class="profile-modal__inner">
    <div class="profile-modal__head">
      <h3 class="profile-modal__title">Photos</h3>
      <button type="button" class="profile-modal__close" aria-label="Close" data-action="click->modal#close">&times;</button>
    </div>
    <%= form_with model: profile, url: profile_path(profile), method: :patch, html: { class: "profile-modal__form", multipart: true, data: { turbo: false } } do |f| %>
      <%= hidden_field_tag :section, "photos" %>
      <div class="profile-modal__field">
        <span class="profile-modal__label">Your uploads</span>
        <% if profile.photos.attached? %>
          <ul class="profile-modal__photo-list">
            <% profile.photos.attachments.each do |attachment| %>
              <li class="profile-modal__photo-item">
                <div class="profile-modal__photo-thumb-wrap">
                  <%= image_tag attachment.variant(resize_to_limit: [ 160, 160 ]), class: "profile-modal__photo-thumb", alt: "" %>
                </div>
                <%= button_to "Delete",
                    destroy_photo_profile_path(profile, attachment_id: attachment.id),
                    method: :delete,
                    class: "btn btn--outline btn--sm profile-modal__photo-delete",
                    onclick: "return confirm('Remove this photo from your profile?');",
                    form: { data: { turbo: false } } %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="profile-modal__hint profile-modal__hint--block">No photos uploaded yet. Add some below.</p>
        <% end %>
      </div>
      <div class="profile-modal__field profile-modal__check">
        <%= f.check_box :has_photo %>
        <%= f.label :has_photo, "I have profile photos (shown to matches)", class: "profile-modal__label-inline" %>
      </div>
      <div class="profile-modal__field">
        <%= f.label :photos, "Add more photos", class: "profile-modal__label" %>
        <%= f.file_field :photos, multiple: true, accept: "image/*", class: "profile-modal__input" %>
        <p class="profile-modal__hint">New files are appended to your gallery. Use Delete on each image to remove it.</p>
      </div>
      <div class="profile-modal__actions">
        <%= f.submit "Save", class: "btn btn--primary" %>
        <button type="button" class="btn btn--outline" data-action="click->modal#close">Cancel</button>
      </div>
    <% end %>
  </div>
</dialog>

<dialog id="profile-edit-about" class="profile-modal" data-controller="modal" data-action="click->modal#backdropClose">
  <div class="profile-modal__inner">
    <div class="profile-modal__head">
      <h3 class="profile-modal__title">About me</h3>
      <button type="button" class="profile-modal__close" aria-label="Close" data-action="click->modal#close">&times;</button>
    </div>
    <%= form_with model: profile, url: profile_path(profile), method: :patch, html: { class: "profile-modal__form", data: { turbo: false } } do |f| %>
      <%= hidden_field_tag :section, "about" %>
      <div class="profile-modal__field">
        <%= f.label :bio, class: "profile-modal__label" %>
