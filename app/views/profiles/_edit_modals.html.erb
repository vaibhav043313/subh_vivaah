<dialog id="profile-edit-visibility" class="profile-modal" data-controller="modal" data-action="click->modal#backdropClose">
  <div class="profile-modal__inner">
    <div class="profile-modal__head">
      <h3 class="profile-modal__title">Visibility</h3>
      <button type="button" class="profile-modal__close" aria-label="Close" data-action="click->modal#close">&times;</button>
    </div>
    <%= form_with model: profile, url: profile_path(profile), method: :patch, html: { class: "profile-modal__form", data: { turbo: false } } do |f| %>
      <%= hidden_field_tag :section, "visibility" %>
      <div class="profile-modal__field">
        <%= f.label :visibility, "Who can see your profile", class: "profile-modal__label" %>
        <%= f.select :visibility,
                     Profile.visibilities.keys.map { |k| [ k.to_s.humanize, k ] },
                     {},
                     { class: "profile-modal__input" } %>
      </div>
      <p class="profile-modal__hint">Verification and completion are updated automatically when you save other sections.</p>
      <div class="profile-modal__actions">
        <%= f.submit "Save", class: "btn btn--primary" %>
        <button type="button" class="btn btn--outline" data-action="click->modal#close">Cancel</button>
      </div>
    <% end %>
  </div>
</dialog>
