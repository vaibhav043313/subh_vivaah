<% content_for :title, "Search & Browse — Subh Vivaah" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "browse", "data-turbo-track": "reload" %>
<% end %>

<div class="browse-page">
  <%= render "shared/app_header" %>

  <div class="browse-layout container container--wide">
    <aside class="browse-layout__sidebar" aria-label="Filters">
      <%= render "filters_sidebar" %>
    </aside>

    <div class="browse-layout__main">
      <div class="browse-toolbar">
        <p class="browse-toolbar__summary">
          <% if @total_count.positive? %>
            Showing <strong><%= @first_index %> – <%= @last_index %></strong> of <%= number_with_delimiter(@total_count) %> profiles
          <% else %>
            No profiles match your filters
          <% end %>
        </p>

        <div class="browse-toolbar__chips">
          <% if @filter_params[:age_min].present? && @filter_params[:age_max].present? %>
            <%= link_to profiles_path(profiles_filters_except(:age_min, :age_max)), class: "filter-chip" do %>
              Age: <%= @filter_params[:age_min] %> – <%= @filter_params[:age_max] %>
              <span class="filter-chip__x" aria-hidden="true">×</span>
            <% end %>
          <% end %>
          <% if @filter_params[:city].present? %>
            <%= link_to profiles_path(profiles_filters_except(:city)), class: "filter-chip" do %>
              Location: <%= @filter_params[:city] %>
              <span class="filter-chip__x" aria-hidden="true">×</span>
            <% end %>
          <% end %>
          <% if ActiveModel::Type::Boolean.new.cast(@filter_params[:photo_only]) %>
            <%= link_to profiles_path(profiles_filters_except(:photo_only)), class: "filter-chip" do %>
              Photo only
              <span class="filter-chip__x" aria-hidden="true">×</span>
            <% end %>
          <% end %>
        </div>

        <div class="browse-toolbar__controls">
          <%= form_with url: profiles_path, method: :get, local: true, class: "browse-toolbar__sort" do %>
            <% @filter_params.each do |name, value| %>
              <% next if %w[sort view page].include?(name.to_s) %>
              <% if value.is_a?(Array) %>
                <% value.each do |v| %>
                  <%= hidden_field_tag "#{name}[]", v %>
                <% end %>
              <% elsif value.present? || (%w[photo_only online_now verified_only].include?(name.to_s) && value.to_s == "1") %>
                <%= hidden_field_tag name, value %>
              <% end %>
            <% end %>
            <label class="visually-hidden" for="profiles-sort">Sort by</label>
            <%= select_tag :sort,
                options_for_select(
                  [
                    ["Sort by Recommended", "recommended"],
                    ["Newest first", "newest"],
                    ["Age ↑", "age_asc"],
                    ["Age ↓", "age_desc"]
                  ],
                  @filter_params[:sort].presence || "recommended"
                ),
                class: "input input--select input--sort",
                id: "profiles-sort",
                onchange: "this.form.requestSubmit()" %>
          <% end %>

          <div class="browse-view-toggle" role="group" aria-label="View mode">
            <%= link_to profiles_path(@filter_params.merge(view: "grid", page: 1)), class: "browse-view-toggle__btn #{'is-active' if @view_mode == 'grid'}" do %>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            <% end %>
            <%= link_to profiles_path(@filter_params.merge(view: "list", page: 1)), class: "browse-view-toggle__btn #{'is-active' if @view_mode == 'list'}" do %>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg>
            <% end %>
          </div>
        </div>
      </div>

      <div class="browse-results browse-results--<%= @view_mode %>">
        <% @profiles.each do |profile| %>
          <%= render "profile_card", profile: profile %>
        <% end %>
      </div>

      <% if @total_pages > 1 %>
        <nav class="browse-pagination" aria-label="Pagination">
          <p class="browse-pagination__info">Showing page <%= @page %> of <%= @total_pages %></p>
          <div class="browse-pagination__actions">
            <% if @page > 1 %>
              <%= link_to "Prev", profiles_path(@filter_params.merge(page: @page - 1)), class: "btn btn--outline btn--sm" %>
            <% else %>
              <span class="btn btn--outline btn--sm is-disabled" aria-disabled="true">Prev</span>
            <% end %>
            <% if @page < @total_pages %>
              <%= link_to "Next", profiles_path(@filter_params.merge(page: @page + 1)), class: "btn btn--primary btn--sm" %>
            <% else %>
              <span class="btn btn--primary btn--sm is-disabled" aria-disabled="true">Next</span>
            <% end %>
            <% if @page < @total_pages %>
              <%= link_to "Load more", profiles_path(@filter_params.merge(page: @page + 1)), class: "btn btn--cyan btn--sm" %>
            <% end %>
          </div>
        </nav>
      <% end %>
    </div>
  </div>

  <%= render "listing_footer" %>
</div>
