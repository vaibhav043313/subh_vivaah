<% content_for :title, "Notifications — Subh Vivaah" %>

<div class="<%= site_page_shell_class %>">
  <%= render "shared/app_header" %>

  <main class="<%= site_page_main_class %>">
    <div class="container">
      <%= render "shared/flash_strip" %>
      <div class="mb-4 flex flex-wrap items-baseline justify-between gap-4">
        <h1 class="<%= site_page_title_class(mb: "mb-0") %>">Notifications</h1>
        <% unread = current_user.notifications.unread.count %>
        <% if unread.positive? %>
          <%= button_to "Mark all read", mark_all_read_notifications_path, method: :patch, class: "btn btn--outline btn--sm", form: { data: { turbo: true } } %>
        <% end %>
      </div>
      <p class="<%= site_page_lead_class %>">Profile visits, new messages, and other alerts appear here.</p>

      <% if @notifications.any? %>
        <ul class="<%= site_notif_list_class %>">
          <% @notifications.each do |n| %>
            <li
              class="<%= site_notif_item_class %>"
              <% if n.read_at.nil? %>
                data-notification-unread="true"
                data-controller="notification-read"
                data-notification-read-url-value="<%= read_notification_path(n) %>"
                data-notification-read-unread-value="true"
                data-action="click->notification-read#markOnce"
              <% end %>
            >
              <div class="min-w-0 flex-[1_1_200px]">
                <p class="mb-1 mt-0 text-[15px] font-semibold"><%= n.title %></p>
                <% if n.body.present? %>
                  <p class="mb-2 mt-0 text-sm text-neutral-700"><%= n.body %></p>
                <% end %>
                <p class="mt-1.5 mb-0 text-xs text-[var(--color-muted)]"><%= time_ago_in_words(n.created_at) %> ago</p>
              </div>
              <% path = notification_action_path(n) %>
              <% if path.present? %>
                <div class="flex flex-wrap items-center gap-2">
                  <%= link_to "Open", path, class: "btn btn--outline btn--sm" %>
                </div>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="<%= site_prose_inline_class %>">You have no notifications yet. When someone messages you or views your profile, you will see it here.</p>
      <% end %>
    </div>
  </main>

  <%= render "shared/site_footer" %>
</div>
