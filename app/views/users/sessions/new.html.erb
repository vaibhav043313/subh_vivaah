<% content_for :title, "Sign in — Subh Vivaah" %>

<div class="auth-panel">
  <div class="auth-card">
    <h1 class="auth-card__title">Welcome back</h1>
    <p class="auth-card__lead">Sign in to continue browsing profiles and messages.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <div class="auth-field">
        <%= f.label :email, class: "auth-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-input", placeholder: "you@example.com" %>
      </div>

      <div class="auth-field">
        <%= f.label :password, class: "auth-label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "auth-input" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="auth-field auth-check">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "Keep me signed in on this device" %>
        </div>
      <% end %>

      <div class="auth-actions">
        <%= f.submit "Sign in", class: "btn btn--primary" %>
      </div>
    <% end %>

    <div class="auth-footer-links">
      <%= link_to "Forgot password?", new_user_password_path %>
      <br><br>
      New here?
      <%= link_to "Create an account", new_user_registration_path %>
    </div>
  </div>
</div>
