<% if resource.errors.any? %>
  <div id="error_explanation" class="auth-errors" data-turbo-cache="false">
    <h2><%= pluralize(resource.errors.count, "issue") %> to fix:</h2>
    <ul>
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
