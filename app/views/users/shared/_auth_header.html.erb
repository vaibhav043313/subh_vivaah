<header class="app-header app-header--minimal" role="banner">
  <div class="app-header__inner container container--wide">
    <%= link_to root_path, class: "site-logo site-logo--mark-only", "aria-label": "Subh Vivaah — Home" do %>
      <%= image_tag "logo.png", alt: "", class: "site-logo__mark max-h-[1.5rem]" %>
    <% end %>

    <div class="app-header__actions app-header__actions--minimal">
      <% case controller_name %>
      <% when "registrations" %>
        <%= link_to "Sign in", new_user_session_path, class: "btn btn--outline btn--sm" %>
      <% when "sessions" %>
        <%= link_to "Create account", new_user_registration_path, class: "btn btn--primary btn--sm" %>
      <% else %>
        <%= link_to "Sign in", new_user_session_path, class: "btn btn--outline btn--sm" %>
        <%= link_to "Create account", new_user_registration_path, class: "btn btn--primary btn--sm" %>
      <% end %>
    </div>
  </div>
</header>
