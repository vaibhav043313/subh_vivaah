<% content_for :title, "Set new password — Subh Vivaah" %>

<div class="auth-panel">
  <div class="auth-card">
    <h1 class="auth-card__title">Set a new password</h1>
    <p class="auth-card__lead">Choose a strong password you haven’t used elsewhere.</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
      <%= render "users/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="auth-field">
        <%= f.label :password, "New password", class: "auth-label" %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "auth-input" %>
        <% if @minimum_password_length %>
          <p class="auth-hint"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
      </div>

      <div class="auth-field">
        <%= f.label :password_confirmation, "Confirm new password", class: "auth-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "auth-input" %>
      </div>

      <div class="auth-actions">
        <%= f.submit "Update password", class: "btn btn--primary" %>
      </div>
    <% end %>
  </div>
</div>
